<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Product - <%= product.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>
    <div class="container mt-5">
        <a href="/products" class="btn btn-secondary mb-3">Back to Products</a>

        <div class="card">
            <div class="card-header">
                <h3><%= product.name %></h3>
            </div>
            <div class="card-body">
                <img src="<%= product.image_url %>" alt="<%= product.name %>" class="img-fluid mb-3" style="max-width: 300px;">
                <p><strong>Description:</strong> <%= product.description %></p>
                <p><strong>Price:</strong> $<%= product.price %></p>
                <p><strong>ID:</strong> <%= product.id %></p>
                <p><strong>Category:</strong> <%= product.category_id %></p>
            </div>
            <div class="card-footer d-flex gap-2">
                <a href="/products/editform/<%= product.id %>" class="btn btn-warning">Edit Product</a>
                <a href="/products/deleteconfirm/<%= product.id %>" class="btn btn-danger">Delete Product</a>
            </div>
        </div>
    </div>
</body>
</html>
